# Groq API for LLM inference (fast, free tier available)
# Get yours at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# LibreTranslate (self-hosted, free) OR MyMemory (no key needed for basic use)
# Leave blank to use MyMemory free API (no key required)
TRANSLATE_API_KEY=

# Optional: ElevenLabs or similar for TTS
TTS_API_KEY=

# Backend port
PORT=3001
