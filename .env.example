# Groq API — used for English queries (LLaMA 3.1 8B, fast)
# Get yours at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# HuggingFace API — used for Hinglish/Hindi queries (Mistral 7B, better vernacular)
# Get yours at: https://huggingface.co/settings/tokens
HF_API_KEY=your_huggingface_api_key_here

# LibreTranslate (self-hosted, free) OR MyMemory (no key needed for basic use)
# Leave blank to use MyMemory free API (no key required)
TRANSLATE_API_KEY=

# Backend port
PORT=3001
